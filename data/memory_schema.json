        },
        "favorite_drinks": {
            "type": "list",
            "description": "用户常点/喜欢的饮品列表"
        },
        "preferred_store": {
            "type": "string",
            "description": "用户偏好的门店"
        },
        "allergens": {
            "type": "list",
            "description": "用户过敏原列表"
        },
        "price_sensitivity": {
            "type": "enum",
            "values": ["high", "medium", "low"],
            "description": "价格敏感度"
        },
        "last_order_id": {
            "type": "string",
