            "type": "enum",
            "values": ["无糖", "三分糖", "五分糖", "七分糖", "正常糖"],
            "description": "用户偏好糖度"
        },
        "ice_level": {
            "type": "enum",
            "values": ["热", "温", "去冰", "少冰", "正常冰"],
