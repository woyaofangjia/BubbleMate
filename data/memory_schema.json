            "timestamp": "datetime",
            "resolved": "boolean",
            "solution": "string"
        }
    },
    "interaction_stats": {
        "total_interactions": "integer",
        "total_orders": "integer",
        "total_complaints": "integer",
        "avg_interaction_duration": "float",
